# Server Configuration
PORT=3000
NODE_ENV=development

# Database - Replace with your MongoDB credentials
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/DevTinder

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5174
PRODUCTION_FRONTEND_URL=https://devconnect-frontend-beta.vercel.app

# JWT Secret - Use a strong, random string in production
JWT_SECRET=DevTinderSecret123!@#

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: For production monitoring
# SENTRY_DSN=your-sentry-dns
# LOG_LEVEL=info
